{
  "name": "packing-recorder",
  "version": "2.1.6",
  "description": "Packing video recording system with barcode scanner support",
  "author": {
    "name": "Jason Aldeo Leonard",
    "email": "aldeojason@gmail.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.packingrecorder.app",
    "productName": "Packing Recorder",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "i18n.js",
      "print-stations.html",
      "styles.css",
      "videos/",
      "node_modules/ffmpeg-static/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "artifactName": "PackingRecorder-Setup.exe",
    "publish": {
      "provider": "github",
      "owner": "JasonAldeo",
      "repo": "packing-recorder"
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "qrcode": "^1.5.4"
  }
}
