# ─── Database (Railway provides this automatically) ───────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Midtrans ─────────────────────────────────────────────────────────────────
# Get these from https://dashboard.midtrans.com → Settings → Access Keys
MIDTRANS_SERVER_KEY=SB-Mid-server-XXXXXXXXXXXXXXXXXXXXXXXX
MIDTRANS_CLIENT_KEY=SB-Mid-client-XXXXXXXXXXXXXXXXXXXXXXXX

# Set to "production" when going live (uses api.midtrans.com instead of sandbox)
MIDTRANS_ENVIRONMENT=sandbox

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000

# The public URL of this server (set automatically by Railway, but used in logs)
# e.g. https://packing-recorder-license.up.railway.app
PUBLIC_URL=https://your-app.up.railway.app
